<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Defense in depth: no cleartext; release builds also omit INTERNET. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
